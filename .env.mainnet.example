# NILE Security — Mainnet Production Configuration
# Copy to .env on your production server and fill in ALL values.

# --- Environment ---
NILE_ENV=production
NILE_DEBUG=false

# --- Database ---
NILE_DATABASE_URL=postgresql+asyncpg://nile:CHANGE_ME@db-host:5432/nile_solana
NILE_DATABASE_ECHO=false

# --- Redis ---
NILE_REDIS_URL=redis://redis-host:6379/0

# --- AI APIs ---
NILE_ANTHROPIC_API_KEY=sk-ant-...
NILE_OPENAI_API_KEY=

# --- Security (REQUIRED) ---
NILE_API_KEY=nile_prod_...
NILE_JWT_SECRET=GENERATE_A_64_CHAR_RANDOM_STRING_HERE
NILE_CORS_ORIGINS=["https://nile.security","https://www.nile.security"]

# --- Solana (mainnet-beta) ---
NILE_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
NILE_SOLANA_NETWORK=mainnet-beta
NILE_PROGRAM_ID=               # Set after anchor deploy
NILE_ORACLE_PROGRAM_ID=        # Set after anchor deploy
NILE_TREASURY_PROGRAM_ID=      # Set after anchor deploy
NILE_DEPLOYER_KEYPAIR_PATH=/keys/deployer.json

# --- Pyth Oracle (Mainnet) ---
NILE_PYTH_SOL_USD_FEED=H6ARHf6YXhGYeQfUzQNGk6rDNnLBQKrenN712K4AQJEG

# --- Frontend ---
NEXT_PUBLIC_API_URL=https://api.nile.security
