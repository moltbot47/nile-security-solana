# NILE Security for Solana — Configuration
# Copy to .env and fill in values.
# For mainnet, see .env.mainnet.example below.

# --- Environment ---
NILE_ENV=development          # development | staging | production
NILE_DEBUG=true

# --- Database ---
NILE_DATABASE_URL=postgresql+asyncpg://nile:nile@localhost:5432/nile_solana
NILE_DATABASE_ECHO=false

# --- Redis ---
NILE_REDIS_URL=redis://localhost:6379/0

# --- AI APIs ---
NILE_ANTHROPIC_API_KEY=
NILE_OPENAI_API_KEY=

# --- Security ---
NILE_API_KEY=
NILE_JWT_SECRET=              # REQUIRED in production (will crash if default)
NILE_CORS_ORIGINS=["http://localhost:3000"]

# --- Solana ---
NILE_SOLANA_RPC_URL=https://api.devnet.solana.com
NILE_SOLANA_NETWORK=devnet    # devnet | testnet | mainnet-beta
NILE_PROGRAM_ID=
NILE_ORACLE_PROGRAM_ID=
NILE_TREASURY_PROGRAM_ID=
NILE_DEPLOYER_PRIVATE_KEY=
NILE_DEPLOYER_KEYPAIR_PATH=

# --- Pyth Oracle ---
# Devnet:  J83w4HKfqxwcq3BEMMkPFSppX3gqekLyLJBexebFVkix
# Mainnet: H6ARHf6YXhGYeQfUzQNGk6rDNnLBQKrenN712K4AQJEG
NILE_PYTH_SOL_USD_FEED=J83w4HKfqxwcq3BEMMkPFSppX3gqekLyLJBexebFVkix

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
